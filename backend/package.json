{
  "name": "umi-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute umi-db --local --file=./src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute umi-db --local --file=./src/db/seed.sql",
    "db:setup:local": "npm run db:migrate:local && npm run db:seed:local"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "wrangler": "^4.14.0",
    "typescript": "^5.8.0"
  }
}
